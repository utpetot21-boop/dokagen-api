# =============================================================================
# DokaGen API — Environment Variables PRODUCTION
# Salin file ini: cp .env.production.template .env
# Isi semua nilai yang kosong sebelum deploy
# JANGAN commit file .env ke git!
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# URL frontend web (untuk CORS)
# Ganti dengan domain Vercel Anda
CLIENT_URL=https://dokagen.vercel.app

# ── Database PostgreSQL ───────────────────────────────────────────────────────
# Sesuai yang dibuat oleh script 1-setup-vps.sh
DATABASE_URL=postgresql://dokagen:DokAGen_DB_2026!@localhost:5432/dokagen_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Buat secret kuat: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_SECRET_PANJANG_64_KARAKTER
JWT_REFRESH_SECRET=GANTI_DENGAN_REFRESH_SECRET_BERBEDA_64_KARAKTER
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Internal API Key (untuk job scheduler antar service) ─────────────────────
# Buat: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=GANTI_DENGAN_RANDOM_32_BYTES_HEX

# ── SMTP Email (opsional — untuk kirim invoice via email) ─────────────────────
# Contoh pakai Gmail: aktifkan App Password di Google Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=email@gmail.com
SMTP_PASS=app_password_gmail_anda
SMTP_FROM_NAME=DokaGen

# ── Firebase FCM (opsional — untuk push notification) ────────────────────────
# Download service account JSON dari Firebase Console
# Pilih salah satu cara:
FIREBASE_SERVICE_ACCOUNT_PATH=/var/www/dokagen-api/firebase-service-account.json
# ATAU paste JSON langsung (escape quotes):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Upload storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=/var/www/dokagen-api/uploads
UPLOAD_BASE_URL=https://api.dokagen.id
